  "keyFeatures": [
    "Multi-language SDKs (Python, TypeScript, Go) for serverless compute",
    "Declarative container image building with custom dependencies",
    "Serverless function execution with automatic scaling",
    "Stateful class-based services with lifecycle management",
    "Interactive sandboxes for arbitrary code execution",
    "Persistent storage with Volumes and Network File Systems",
    "Queue and Dict primitives for distributed applications",
    "Web endpoint decorators for HTTP/ASGI/WSGI services",
    "GPU and accelerator configuration support",
    "Secret management and environment configuration",
    "Parallel execution with map and batch operations",
    "CLI tools for deployment and management"
  ],
  "publicApiSurface": [
    "modal.App - Main application container",
    "modal.Function - Serverless function decorator and runtime",
    "modal.Cls - Stateful class decorator and lifecycle",
    "modal.Image - Container image builder",
    "modal.Sandbox - Interactive container runtime",
    "modal.Volume - Persistent file storage",
    "modal.NetworkFileSystem - Shared network file system",
    "modal.CloudBucketMount - S3/GCS bucket mounting",
    "modal.Dict - Key-value store",
    "modal.Queue - Message queue",
    "modal.Secret - Secret management",
    "modal.Client - SDK client for programmatic access",
    "@modal.web_endpoint - HTTP endpoint decorator",
    "@modal.asgi_app - ASGI application decorator",
    "@modal.batched - Batching decorator for functions",
    "@modal.concurrent - Concurrent execution control",
    "modal.Retries - Retry configuration",
    "modal.Cron / modal.Period - Scheduled execution",
    "modal.GPU - GPU configuration",
    "modal.SchedulerPlacement - Scheduler placement hints",
    "ModalClient (JS/TS) - TypeScript SDK client",
    "modal.NewClient (Go) - Go SDK client"
  ]
}
